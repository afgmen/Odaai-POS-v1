# Server
PORT=3000
NODE_ENV=development

# GrabFood OAuth2 credentials
GRAB_CLIENT_ID=your_grab_client_id
GRAB_CLIENT_SECRET=your_grab_client_secret
GRAB_ENVIRONMENT=sandbox
# sandbox  → https://partner-api.grab.com/grabfood-sandbox
# production → https://partner-api.grab.com/grabfood

# GrabFood webhook signature secret
GRAB_WEBHOOK_SECRET=your_grab_webhook_secret

# WebSocket heartbeat interval (ms)
WS_HEARTBEAT_INTERVAL=30000
